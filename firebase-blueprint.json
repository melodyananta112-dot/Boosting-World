{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's full name" },
        "phoneNumber": { "type": "string", "description": "User's phone number" },
        "address": { "type": "string", "description": "User's delivery address" },
        "balance": { "type": "number", "description": "User's account balance" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details",
      "type": "object",
      "properties": {
        "orderId": { "type": "string", "description": "Unique order ID" },
        "orderNumber": { "type": "string", "description": "Random 4-digit order number (e.g., #4829)" },
        "numericId": { "type": "number", "description": "Numeric part of the order number" },
        "userId": { "type": "string", "description": "ID of the user who placed the order" },
        "items": { "type": "array", "description": "List of items in the order" },
        "totalAmount": { "type": "number", "description": "Total price of the order" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"], "description": "Current status of the order" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Order placement timestamp" },
        "shippingAddress": { "type": "string", "description": "Address for delivery" },
        "customerPhone": { "type": "string", "description": "Contact phone for the order" }
      },
      "required": ["userId", "items", "totalAmount", "status", "createdAt"]
    },
    "Deposit": {
      "title": "Deposit",
      "description": "User deposit request",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user" },
        "amount": { "type": "number", "description": "Amount to deposit" },
        "method": { "type": "string", "enum": ["bkash", "nagad", "rocket"], "description": "Payment method" },
        "transactionId": { "type": "string", "description": "Transaction ID from the payment" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Status of the deposit" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Deposit request timestamp" }
      },
      "required": ["userId", "amount", "method", "transactionId", "status", "createdAt"]
    },
    "Service": {
      "title": "Service",
      "description": "Service offered by the platform",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "platform": { "type": "string" },
        "description": { "type": "string" },
        "averageTime": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["name", "price", "category", "platform"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Site-wide settings",
      "type": "object",
      "properties": {
        "bkashNumber": { "type": "string" },
        "whatsappLink": { "type": "string" }
      }
    },
    "Counter": {
      "title": "Counter",
      "description": "Sequential ID counters",
      "type": "object",
      "properties": {
        "nextId": { "type": "number" },
        "availableIds": { "type": "array", "items": { "type": "number" } }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of orders"
    },
    "/deposits/{depositId}": {
      "schema": "Deposit",
      "description": "Collection of deposit requests"
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Collection of services"
    },
    "/settings/site": {
      "schema": "Settings",
      "description": "Site configuration"
    },
    "/counters/{counterId}": {
      "schema": "Counter",
      "description": "Collection of counters for ID generation"
    }
  }
}
